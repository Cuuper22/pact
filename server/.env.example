# Pact relay configuration. Copy to .env and fill in. Every value has a sane
# default except the push credentials; without those the relay runs fully and
# just logs instead of sending notifications.

# --- core ---
PORT=8787
# Public origin clients reach. Used to build the wsUrl and is rewritten to
# ws:// or wss:// automatically. In production set this to your https origin.
PUBLIC_URL=http://localhost:8787
# Custom URL scheme the apps register; the QR join link uses it.
APP_SCHEME=pact
# How long a pact lives before it purges itself (default 24h).
PACT_TTL_MS=86400000

# --- APNs (iOS push) — all four required to enable iOS push ---
# The .p8 AuthKey contents. Paste with literal \n between PEM lines, e.g.
# APNS_KEY="-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----"
APNS_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
# The app bundle id, used as the apns-topic, e.g. app.pact
APNS_TOPIC=
# Use Apple's sandbox gateway for development builds.
APNS_SANDBOX=true

# --- FCM (Android push) — all three required to enable Android push ---
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
# Service-account private key, literal \n between PEM lines (as above).
FCM_PRIVATE_KEY=
