{
  "name": "@pact/relay",
  "version": "1.0.0",
  "description": "Pact relay — a dumb, ephemeral session relay. Authoritative consent engine, WebSocket fan-out, and push (APNs + FCM). No accounts, no database, sessions purge after 24h.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --import tsx --watch src/index.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pact/engine": "file:../packages/engine",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
