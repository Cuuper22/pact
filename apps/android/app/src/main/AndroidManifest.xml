<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet for REST + WebSocket to the relay. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Usage access: read the foreground app so the shield knows what's open.
         This is a special "appops" permission granted by the user in Settings,
         not at runtime. Requires prominent disclosure on Play (see README). -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Draw the shield over other apps. Granted in Settings, not at runtime. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground service keeps the shield alive while the pact is locked. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Notifications (asks, pass countdowns). Runtime permission on API 33+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Resolve the default dialer/phone packages so we never shield them. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.DIAL" />
        </intent>
        <intent>
            <action android:name="android.intent.action.CALL" />
        </intent>
    </queries>

    <application
        android:name=".PactApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Pact">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Pact">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep link for pact://join?code=... (the QR / joinLink). -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="pact" android:host="join" />
            </intent-filter>
        </activity>

        <!-- The shield foreground service. specialUse type: a present-together
             digital-wellbeing overlay driven by usage access. -->
        <service
            android:name=".shield.ShieldService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Group digital-wellbeing shield: overlays distracting apps while a pact is locked, driven by usage access." />
        </service>

        <!-- Guarded FCM service. Inert when Firebase has no config. -->
        <service
            android:name=".push.PactMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Receives Allow / Not now taps from ask notifications. -->
        <receiver
            android:name=".push.AskActionReceiver"
            android:exported="false" />

        <!-- Default FCM notification channel id (used only if Firebase posts a
             notification message directly; we mostly handle data messages). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="@string/notif_channel_asks" />

    </application>

</manifest>
